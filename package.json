{
  "name": "okf-memory",
  "version": "1.0.0",
  "description": "Project memory for coding agents, stored as an OKF knowledge bundle in memory/ — tracks architecture, decisions, patterns, pitfalls, and setup.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "agent-skills",
    "okf",
    "memory"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "sync": "node scripts/sync.mjs",
    "validate": "node scripts/validate.mjs test/fixtures/valid-memory",
    "preview:dashboard": "node skills/okf/server.mjs < test/fixtures/dashboard.json",
    "preview:init": "node skills/okf-init/server.mjs < test/fixtures/init.json",
    "preview:consolidate": "node skills/okf-init/server.mjs < test/fixtures/consolidate.json",
    "preview:memorize": "node skills/okf-init/server.mjs < test/fixtures/memorize.json"
  }
}
